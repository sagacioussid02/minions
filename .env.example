# =============================================================================
# minions environment — copy to `.env` and fill in.
#
# .env is git-ignored and NEVER read by agents (only by the orchestrator at
# startup). See src/minions/agents/safety.py for the contract.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED for any LLM-backed command (planning, engineer, audit, devil's adv)
# ---------------------------------------------------------------------------

# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# OPTIONAL — Postgres backend for Decision/audit/engineer-run/cost stores
# Leave unset to use the JSON file backend at data/local/. Recommended for
# production deployments. Neon (https://neon.tech) has a free tier.
# ---------------------------------------------------------------------------

# MINIONS_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# MINIONS_STORE_BACKEND=postgres            # force Postgres even if URL is set elsewhere
# MINIONS_STORE_BACKEND=json                # force JSON even if a DB URL is set

# ---------------------------------------------------------------------------
# OPTIONAL — Email approvals via Gmail SMTP (App Password)
#
# Setup:
#   1. Enable 2-Step Verification on the Gmail account that owns the portfolio.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Set the password below and `MINIONS_NOTIFIER=gmail`.
# ---------------------------------------------------------------------------

# MINIONS_NOTIFIER=gmail
# MINIONS_SECRET_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ---------------------------------------------------------------------------
# OPTIONAL — HMAC key for approval magic-link tokens (72h TTL).
# Required if you deploy the webhook receiver. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ---------------------------------------------------------------------------

# MINIONS_TOKEN_SECRET=<48-byte url-safe secret>

# ---------------------------------------------------------------------------
# OPTIONAL — Webhook base URL. When set, approval emails contain clickable
# Approve/Reject buttons; otherwise the email shows CLI commands + raw tokens.
# ---------------------------------------------------------------------------

# MINIONS_WEBHOOK_BASE_URL=https://your-webhook.fly.dev

# ---------------------------------------------------------------------------
# OPTIONAL — GitHub. Falls back to `gh auth token` if unset.
# ---------------------------------------------------------------------------

# GITHUB_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# OPTIONAL — GitHub App for the web onboarding flow (customer repo access).
# In production this is configured once at /admin/github-app (founder-only —
# a one-click manifest flow, no manual dashboard setup) and stored in
# Postgres, not env vars. Set these only to override for local dev.
# ---------------------------------------------------------------------------

# MINIONS_GITHUB_APP_ID=
# MINIONS_GITHUB_APP_PRIVATE_KEY=
# MINIONS_GITHUB_APP_SLUG=
# MINIONS_GITHUB_APP_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# OPTIONAL — Langfuse for crew tracing. No-ops if unset.
# Sign up at https://langfuse.com or self-host.
# ---------------------------------------------------------------------------

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ---------------------------------------------------------------------------
# OPTIONAL — AWS Secrets Manager backend. Falls back silently if unset.
# Lookup pattern: secret name `minions/<key>`.
# ---------------------------------------------------------------------------

# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
