# Same Neon URL the Python crews use (`MINIONS_DATABASE_URL` in repo root .env).
# Copy this file to `.env.local` and fill in the value — `.env.local` is gitignored.
MINIONS_DATABASE_URL=

# Required only for the Sprint Board's operator-triggered auto-merge button.
# Use a fine-scoped GitHub PAT that can merge PRs in the managed project repos.
MINIONS_GH_PAT=

# Optional: override the $50/wk ceiling shown in the CostGauge.
# MINIONS_WEEKLY_CAP_USD=50

# Clerk authentication (P2). Create an application at https://dashboard.clerk.com
# with GitHub as the ONLY enabled sign-in method, then copy both keys here.
# The publishable key is safe to expose; the secret key is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Route Clerk to the in-app auth pages instead of the hosted Account Portal.
# Without these, middleware redirects land on <slug>.accounts.dev.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Founder identity (P3). Real values live in .env.local + deploy secrets only.
# Pin the cap-exempt founder tenant; both must match the seeded tenants row.
MINIONS_FOUNDER_CLERK_ID=user_...
MINIONS_FOUNDER_TENANT_ID=
